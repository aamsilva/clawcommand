# ClawCommand Configuration
# Copy this file to .env and fill in your values

# Company Settings
COMPANY_NAME=Hexa Labs
COMPANY_SHORTNAME=HEX

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Database
DATABASE_PATH=./clawcommand.db

# Heartbeat Interval (seconds)
HEARTBEAT_INTERVAL=900

# Discord Bot (optional)
# Get token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=1476172344333701220

# CEO Agent
CEO_AGENT_ID=henry

# API Server (optional)
API_PORT=3000
API_HOST=localhost