<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Mission Control</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --bg-primary: #0a0f1a;
            --bg-secondary: #1e293b;
            --bg-card: #0f172a;
            --accent: #2251FF;
            --accent-dark: #051C2C;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --border: #334155;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, var(--accent-dark) 0%, var(--bg-card) 100%);
            padding: 15px 30px;
            border-bottom: 3px solid var(--accent);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .header h1 { 
            font-size: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .header-stats {
            display: flex;
            gap: 20px;
            font-size: 13px;
        }
        
        .header-stat {
            text-align: center;
        }
        
        .header-stat .value {
            font-size: 20px;
            font-weight: bold;
            color: var(--accent);
        }
        
        .header-stat .label {
            color: var(--text-secondary);
            font-size: 11px;
        }
        
        /* Navigation */
        .nav-tabs {
            display: flex;
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            padding: 0 30px;
        }
        
        .nav-tab {
            padding: 15px 25px;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .nav-tab:hover {
            background: rgba(34, 81, 255, 0.1);
        }
        
        .nav-tab.active {
            border-bottom-color: var(--accent);
            color: var(--accent);
        }
        
        /* Main Content */
        .main-container {
            display: flex;
            height: calc(100vh - 140px);
        }
        
        /* Left Sidebar - Activity Feed */
        .activity-sidebar {
            width: 320px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
        }
        
        .activity-header {
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            font-weight: 600;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .activity-stream {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
        }
        
        .activity-item {
            padding: 12px;
            margin-bottom: 10px;
            background: var(--bg-card);
            border-radius: 8px;
            border-left: 3px solid var(--accent);
            font-size: 13px;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        .activity-time {
            color: var(--text-secondary);
            font-size: 11px;
            margin-bottom: 4px;
        }
        
        .activity-agent {
            color: var(--accent);
            font-weight: 600;
        }
        
        .activity-action {
            margin-top: 4px;
            color: var(--text-secondary);
        }
        
        /* Main Content Area */
        .content-area {
            flex: 1;
            overflow: auto;
            padding: 25px;
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        /* Task Board - Kanban */
        .kanban-board {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            height: 100%;
        }
        
        .kanban-column {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 15px;
            display: flex;
            flex-direction: column;
        }
        
        .kanban-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border);
        }
        
        .kanban-title {
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .kanban-count {
            background: var(--accent);
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
        }
        
        .kanban-tasks {
            flex: 1;
            overflow-y: auto;
        }
        
        .task-card {
            background: var(--bg-card);
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid transparent;
        }
        
        .task-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
        }
        
        .task-assignee {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            margin-bottom: 8px;
        }
        
        .assignee-badge {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: bold;
        }
        
        .assignee-badge.human { background: var(--accent); }
        .assignee-badge.agent { background: var(--success); }
        
        .task-title {
            font-weight: 500;
            margin-bottom: 8px;
        }
        
        .task-meta {
            display: flex;
            gap: 10px;
            font-size: 11px;
            color: var(--text-secondary);
        }
        
        .task-priority {
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 10px;
        }
        
        .priority-high { background: rgba(239, 68, 68, 0.2); color: var(--danger); }
        .priority-medium { background: rgba(245, 158, 11, 0.2); color: var(--warning); }
        .priority-low { background: rgba(16, 185, 129, 0.2); color: var(--success); }
        
        /* Projects Grid */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        
        .project-card {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border);
            transition: all 0.2s;
        }
        
        .project-card:hover {
            border-color: var(--accent);
        }
        
        .project-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 15px;
        }
        
        .project-title {
            font-size: 18px;
            font-weight: 600;
        }
        
        .project-budget {
            font-size: 12px;
            color: var(--text-secondary);
        }
        
        .project-progress {
            margin: 15px 0;
        }
        
        .progress-bar {
            height: 8px;
            background: var(--bg-card);
            border-radius: 4px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #4f7cff);
            border-radius: 4px;
            transition: width 0.3s;
        }
        
        .project-agents {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }
        
        .project-agent {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 10px;
            background: var(--bg-card);
            border-radius: 20px;
            font-size: 12px;
        }
        
        /* Calendar View */
        .calendar-container {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 20px;
        }
        
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 10px;
        }
        
        .calendar-day {
            background: var(--bg-card);
            border-radius: 8px;
            padding: 10px;
            min-height: 100px;
        }
        
        .calendar-day-header {
            font-size: 12px;
            color: var(--text-secondary);
            margin-bottom: 8px;
        }
        
        .calendar-event {
            background: rgba(34, 81, 255, 0.2);
            border-left: 3px solid var(--accent);
            padding: 5px 8px;
            border-radius: 4px;
            font-size: 11px;
            margin-bottom: 5px;
        }
        
        /* Quick Actions */
        .quick-actions {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .btn-primary {
            background: var(--accent);
            color: white;
        }
        
        .btn-primary:hover {
            background: #3d6fff;
        }
        
        .btn-secondary {
            background: var(--bg-secondary);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }
        
        .btn-secondary:hover {
            border-color: var(--accent);
        }
        
        /* Responsive */
        @media (max-width: 1200px) {
            .kanban-board {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 768px) {
            .activity-sidebar {
                display: none;
            }
            .kanban-board {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div>
            <h1>🎯 Mission Control</h1>
            <div style="color: var(--text-secondary); font-size: 13px; margin-top: 5px;"><%= company %></div>
        </div>
        <div class="header-stats">
            <div class="header-stat">
                <div class="value" id="stat-agents">--</div>
                <div class="label">AGENTS</div>
            </div>
            <div class="header-stat">
                <div class="value" id="stat-projects">--</div>
                <div class="label">PROJECTS</div>
            </div>
            <div class="header-stat">
                <div class="value" id="stat-tasks">--</div>
                <div class="label">TASKS</div>
            </div>
            <div class="header-stat">
                <div class="value status" style="color: var(--success);">●</div>
                <div class="label">ONLINE</div>
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <div class="nav-tabs">
        <div class="nav-tab active" data-tab="tasks">
            📋 Task Board
        </div>
        <div class="nav-tab" data-tab="projects">
            🎯 Projects
        </div>
        <div class="nav-tab" data-tab="calendar">
            📅 Calendar
        </div>
        <div class="nav-tab" data-tab="agents">
            👥 Agents
        </div>
    </div>

    <!-- Main Container -->
    <div class="main-container">
        <!-- Activity Sidebar -->
        <div class="activity-sidebar">
            <div class="activity-header">
                <span>📡 Live Activity</span>
                <span style="font-size: 11px; color: var(--success);">● LIVE</span>
            </div>
            <div class="activity-stream" id="activity-stream">
                <div class="loading" style="padding: 20px; text-align: center; color: var(--text-secondary);">
                    Connecting to activity stream...
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="content-area">
            <!-- Task Board Tab -->
            <div id="tab-tasks" class="tab-content active">
                <div class="quick-actions">
                    <button class="btn btn-primary" onclick="createNewTask()">
                        ➕ New Task
                    </button>
                    <button class="btn btn-secondary" onclick="refreshBoard()">
                        🔄 Refresh
                    </button>
                </div>
                
                <div class="kanban-board" id="kanban-board">
                    <!-- Columns will be populated by JavaScript -->
                </div>
            </div>

            <!-- Projects Tab -->
            <div id="tab-projects" class="tab-content">
                <div class="quick-actions">
                    <button class="btn btn-primary" onclick="createNewProject()">
                        ➕ New Project
                    </button>
                </div>
                <div class="projects-grid" id="projects-grid">
                    <!-- Projects populated by JavaScript -->
                </div>
            </div>

            <!-- Calendar Tab -->
            <div id="tab-calendar" class="tab-content">
                <div class="calendar-container">
                    <div class="calendar-header">
                        <h2>📅 Scheduled Tasks & Cron Jobs</h2>
                        <span style="color: var(--text-secondary);">Next 7 days</span>
                    </div>
                    <div class="calendar-grid" id="calendar-grid">
                        <!-- Calendar populated by JavaScript -->
                    </div>
                </div>
            </div>

            <!-- Agents Tab -->
            <div id="tab-agents" class="tab-content">
                <div id="agents-list">
                    <!-- Agents list populated by JavaScript -->
                </div>
            </div>
        </div>
    </div>

    <script>
        // State
        let currentTab = 'tasks';
        let agents = [];
        let projects = [];
        let tasks = [];
        let activities = [];

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            initTabs();
            initWebSocket();
            loadAllData();
        });

        // Tab Navigation
        function initTabs() {
            document.querySelectorAll('.nav-tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    const tabName = tab.dataset.tab;
                    switchTab(tabName);
                });
            });
        }

        function switchTab(tabName) {
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            
            document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
            document.getElementById(`tab-${tabName}`).classList.add('active');
            
            currentTab = tabName;
        }

        // WebSocket for real-time updates
        function initWebSocket() {
            const ws = new WebSocket(`ws://${window.location.host}`);
            
            ws.onopen = () => {
                console.log('Mission Control connected');
                addActivity('System', 'Connected to Mission Control', 'success');
            };
            
            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                handleRealtimeUpdate(data);
            };
            
            ws.onerror = (err) => {
                console.error('WebSocket error:', err);
                addActivity('System', 'Connection error - retrying...', 'error');
            };
        }

        // Load all data
        async function loadAllData() {
            try {
                const [agentsRes, projectsRes, tasksRes] = await Promise.all([
                    fetch('/api/agents'),
                    fetch('/api/projects'),
                    fetch('/api/tasks')
                ]);
                
                agents = await agentsRes.json();
                projects = await projectsRes.json();
                tasks = await tasksRes.json();
                
                updateHeaderStats();
                renderKanbanBoard();
                renderProjects();
                renderCalendar();
                renderAgents();
                
            } catch (err) {
                console.error('Error loading data:', err);
                addActivity('System', 'Failed to load data', 'error');
            }
        }

        function updateHeaderStats() {
            document.getElementById('stat-agents').textContent = agents.length;
            document.getElementById('stat-projects').textContent = projects.length;
            document.getElementById('stat-tasks').textContent = tasks.length;
        }

        // Kanban Board
        function renderKanbanBoard() {
            const columns = [
                { id: 'backlog', title: '📥 Backlog', color: '#64748b' },
                { id: 'in_progress', title: '🔄 In Progress', color: '#2251FF' },
                { id: 'review', title: '👀 Review', color: '#f59e0b' },
                { id: 'done', title: '✅ Done', color: '#10b981' }
            ];
            
            const board = document.getElementById('kanban-board');
            board.innerHTML = columns.map(col => {
                const colTasks = tasks.filter(t => t.status === col.id);
                return `
                    <div class="kanban-column">
                        <div class="kanban-header">
                            <div class="kanban-title" style="color: ${col.color}">
                                ${col.title}
                            </div>
                            <div class="kanban-count">${colTasks.length}</div>
                        </div>
                        <div class="kanban-tasks">
                            ${colTasks.map(task => renderTaskCard(task)).join('')}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderTaskCard(task) {
            const assignee = agents.find(a => a.id === task.assignee_id);
            const isHuman = !assignee || assignee.name === 'Augusto';
            const badgeClass = isHuman ? 'human' : 'agent';
            const badgeText = isHuman ? 'A' : 'H';
            
            return `
                <div class="task-card" data-task-id="${task.id}">
                    <div class="task-assignee">
                        <div class="assignee-badge ${badgeClass}">${badgeText}</div>
                        <span>${assignee ? assignee.name : 'Unassigned'}</span>
                    </div>
                    <div class="task-title">${task.title}</div>
                    <div class="task-meta">
                        <span class="task-priority priority-${task.priority || 'medium'}">
                            ${task.priority || 'medium'}
                        </span>
                        <span>€${task.budget || 0}</span>
                    </div>
                </div>
            `;
        }

        // Projects
        function renderProjects() {
            const grid = document.getElementById('projects-grid');
            grid.innerHTML = projects.map(project => {
                const projectAgents = agents.filter(a => 
                    tasks.some(t => t.project_id === project.id && t.assignee_id === a.id)
                );
                const progress = calculateProjectProgress(project);
                
                return `
                    <div class="project-card">
                        <div class="project-header">
                            <div>
                                <div class="project-title">${project.title}</div>
                                <div class="project-budget">Budget: €${project.budget_spent || 0} / €${project.budget_allocated}</div>
                            </div>
                        </div>
                        <div class="project-progress">
                            <div style="display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px;">
                                <span>Progress</span>
                                <span>${progress}%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: ${progress}%"></div>
                            </div>
                        </div>
                        <div class="project-agents">
                            ${projectAgents.map(a => `
                                <div class="project-agent">
                                    <span>${a.name}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function calculateProjectProgress(project) {
            const projectTasks = tasks.filter(t => t.project_id === project.id);
            if (projectTasks.length === 0) return 0;
            const doneTasks = projectTasks.filter(t => t.status === 'done').length;
            return Math.round((doneTasks / projectTasks.length) * 100);
        }

        // Calendar
        function renderCalendar() {
            const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const grid = document.getElementById('calendar-grid');
            
            // Get next 7 days
            const today = new Date();
            
            grid.innerHTML = days.map((day, i) => {
                const date = new Date(today);
                date.setDate(today.getDate() + i);
                const dayTasks = tasks.filter(t => {
                    if (!t.due_date) return false;
                    const due = new Date(t.due_date);
                    return due.toDateString() === date.toDateString();
                });
                
                return `
                    <div class="calendar-day">
                        <div class="calendar-day-header">${day} ${date.getDate()}</div>
                        ${dayTasks.map(t => `
                            <div class="calendar-event">${t.title}</div>
                        `).join('')}
                    </div>
                `;
            }).join('');
        }

        // Agents
        function renderAgents() {
            const container = document.getElementById('agents-list');
            container.innerHTML = `
                <div style="background: var(--bg-secondary); border-radius: 12px; padding: 20px;">
                    <h2 style="margin-bottom: 20px;">Active Agents (${agents.length})</h2>
                    <div style="display: grid; gap: 15px;">
                        ${agents.map(agent => `
                            <div style="background: var(--bg-card); padding: 15px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <div style="font-weight: 600;">${agent.name}</div>
                                    <div style="font-size: 12px; color: var(--text-secondary);">${agent.title}</div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="color: ${agent.status === 'idle' ? 'var(--success)' : 'var(--warning)'};">
                                        ${agent.status}
                                    </div>
                                    <div style="font-size: 12px; color: var(--text-secondary);">
                                        ${agent.activeTasks || 0} tasks
                                    </div>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        // Activity Stream
        function addActivity(agent, action, type = 'info') {
            const stream = document.getElementById('activity-stream');
            const time = new Date().toLocaleTimeString();
            
            const activity = document.createElement('div');
            activity.className = 'activity-item';
            activity.innerHTML = `
                <div class="activity-time">${time}</div>
                <div class="activity-agent">${agent}</div>
                <div class="activity-action">${action}</div>
            `;
            
            stream.insertBefore(activity, stream.firstChild);
            
            // Keep only last 50 activities
            while (stream.children.length > 50) {
                stream.removeChild(stream.lastChild);
            }
        }

        function handleRealtimeUpdate(data) {
            if (data.type === 'activity') {
                addActivity(data.agent, data.action, data.status);
            } else if (data.type === 'task_update') {
                loadAllData(); // Refresh all data
                addActivity(data.agent, `Updated task: ${data.task}`, 'info');
            }
        }

        // Actions
        function createNewTask() {
            const title = prompt('Task title:');
            if (title) {
                addActivity('You', `Created task: ${title}`, 'info');
                // TODO: API call to create task
            }
        }

        function createNewProject() {
            const title = prompt('Project title:');
            if (title) {
                addActivity('You', `Created project: ${title}`, 'info');
                // TODO: API call to create project
            }
        }

        function refreshBoard() {
            loadAllData();
            addActivity('System', 'Board refreshed', 'info');
        }

        // Auto-refresh every 30 seconds
        setInterval(loadAllData, 30000);
    </script>
</body>
</html>
